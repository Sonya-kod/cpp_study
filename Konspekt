// базовая программа 
#include <iostream>
int main() {
    return 0;
}

 команда #include <iostream>. Команда #include говорит, что мы хотим подключить библиотеку, 
содержащую разные функции, которые реализовали другие программисты.
После #include в треугольных скобках идёт название библиотеки, в нашем случае — iostream(нужна для
ввода и вывода в консоль)
#include <iostream>
int main() {
    std::cout << "Hello"; // вывод Hello
    std::cout << "World!"; // вывод World!
    return 0;
}

                  
#include <iostream>
using namespace std;
int main() {
    cout << "Hello"; // вывод Hello
    cout << "World!"; // вывод World!
    return 0;
}

Команда endl передается в виде правого операнда для оператора <<. 
Она перемещает курсор на новую строку после вывода.

Для вывода текста в консоль используется объект std::cout

#include <iostream>
using namespace std;
int main() {
    cout << "Hello" << endl; // вывод и перенос на новую строку
    cout << " World!" << endl; // вывод и перенос на новую строку
    return 0;
}

Все команды выполняются строго сверху вниз

Форматированный вывод
#include <iostream>
using namespace std;
int main() {
    cout << "5 + 7 = " << 12 << endl; // 5 + 7 = 12
    cout << 5 << " + " << 7 << " = " << 12 << endl; // 5 + 7 = 12
    cout << 3 << " " << 6 << endl; // вывод двух чисел через пробел, то есть 3 6
    return 0;
}

В конце каждой строки в C++ ставится точка с запятой (;). 
Это обязательный элемент синтаксиса языка C++.

